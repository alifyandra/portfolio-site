# Copy to .env for local development: `cp .env.example .env`
# These defaults work with `docker compose up` out of the box.

APP_ENV=development
PORT=8080
AUTO_MIGRATE=true

# --- Postgres (host = the compose service name) ---
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio
POSTGRES_DB=portfolio
DATABASE_URL=postgres://portfolio:portfolio@postgres:5432/portfolio?sslmode=disable

# --- Redis (cache only) ---
REDIS_URL=redis://redis:6379/0

# --- CORS: allowed frontend origins (comma-separated) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- AWS / S3 / SQS ---
# Local: S3 -> MinIO, SQS -> ElasticMQ (only with --profile async).
# Prod:  unset the *_ENDPOINT_URL vars, use real AWS creds (or an IAM role),
#        set S3_FORCE_PATH_STYLE=false and a real SQS_QUEUE_URL.
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=portfolio-assets
S3_ENDPOINT_URL=http://minio:9000
S3_FORCE_PATH_STYLE=true
SQS_ENDPOINT_URL=
SQS_QUEUE_URL=

# --- Spotify proxy (leave blank to disable; the API degrades gracefully) ---
# Obtain via the Authorization Code flow for the account "alifyandraid".
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# --- Email notifications via AWS SES ---
# SES_SENDER_EMAIL must be a verified SES identity. Blank => email disabled
# (contact messages are still stored). Contact-form alerts go to CONTACT_NOTIFY_TO.
# Sending also requires SQS configured + the worker running (--profile async).
SES_SENDER_EMAIL=
CONTACT_NOTIFY_TO=alifyandra@gmail.com

# --- Auth / Google OAuth (see ADR 10; leave client id/secret blank to disable) ---
# Create an OAuth 2.0 Client (type "Web application") in Google Cloud Console and
# register GOOGLE_REDIRECT_URL as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback
# Comma-separated verified Google emails granted the admin role (re-checked on
# every login). Everyone else who signs in becomes a member.
ADMIN_EMAILS=
# Comma-separated verified Google emails granted the friend role: the tier
# between member and admin, with access to friends-only tools (e.g. the WhatsApp
# sender). Re-checked on every login; admin takes precedence over friend.
FRIEND_EMAILS=
# Scope the session cookie. Blank for local dev (host-only); ".aliflabs.dev" in
# prod so it is shared across the apex and the api subdomain.
SESSION_COOKIE_DOMAIN=
# Where the OAuth callback sends the browser after a successful sign-in.
FRONTEND_URL=http://localhost:3000

# --- WhatsApp Sender sidecar (see ADR 11; leave URL blank to disable sends) ---
# The private whatsapp-web.js + Chromium sidecar the backend dials to run a batch.
# Blank URL => template/list CRUD still works but POST /api/wa/batches reports
# "not configured". The shared secret is required whenever the URL is set.
# Local dev: run the sidecar (its own repo, `docker compose up`) and point here at
# http://host.docker.internal:8081 with a matching WA_SIDECAR_SECRET.
WA_SIDECAR_URL=
WA_SIDECAR_SECRET=

# How the backend reaches a sidecar for each batch:
#   static  (default, local dev) — dial the fixed WA_SIDECAR_URL above.
#   fargate (prod, SSM-managed)  — launch a per-batch ECS Fargate task, stream to
#                                  its private IP, then stop it. Nothing runs while
#                                  idle. In fargate mode WA_SIDECAR_URL is unused.
WA_SIDECAR_MODE=static
# fargate-only, set by Terraform in prod (see deploy/terraform/ssm.tf + whatsapp.tf);
# leave blank for local static mode. WA_ASSIGN_PUBLIC_IP must be true when the task
# runs in a public subnet with no NAT (needed to pull ECR + read SSM).
# WA_ECS_CLUSTER=
# WA_TASK_DEFINITION=
# WA_SUBNET_IDS=subnet-aaa,subnet-bbb
# WA_SECURITY_GROUP_ID=
# WA_ASSIGN_PUBLIC_IP=true
# WA_SIDECAR_PORT=8081

# --- Digest / scheduled heavy-compute jobs (see ADR 0013) ---
# The scheduled digest.build Job fetches public Sources and summarizes them with
# the Anthropic Messages API into a dated Digest. Blank ANTHROPIC_API_KEY => the
# builder degrades to a no-op (the Job is acked, nothing written), like Spotify/SES.
ANTHROPIC_API_KEY=
DIGEST_MODEL=claude-haiku-4-5
DIGEST_MAX_TOKENS=4096
# How the worker runs digest.build:
#   local   (default, local dev) — run the builder inline in the worker process.
#   fargate (prod, SSM-managed)  — launch a run-to-completion ECS Fargate task,
#                                  block on DescribeTasks until it stops, ack SQS
#                                  only on exit 0. Nothing runs while idle.
DIGEST_MODE=local
# fargate-only, set by Terraform in prod; leave blank for local. DIGEST_CONTAINER_NAME
# must match the container name in the task definition that runs the `digest` binary.
# WA_ASSIGN_PUBLIC_IP-style rule applies: DIGEST_ASSIGN_PUBLIC_IP must be true in a
# public subnet with no NAT (to pull ECR + read the Anthropic key from SSM).
# DIGEST_ECS_CLUSTER=
# DIGEST_TASK_DEFINITION=
# DIGEST_CONTAINER_NAME=digest
# DIGEST_SUBNET_IDS=subnet-aaa,subnet-bbb
# DIGEST_SECURITY_GROUP_ID=
# DIGEST_ASSIGN_PUBLIC_IP=true

# --- Production only (used by docker-compose.prod.yml) ---
DOMAIN=
IMAGE_TAG=latest
# Key the rate limiter off CF-Connecting-IP instead of the connecting IP. Only
# safe once the origin is locked to Cloudflare's ranges (the header is otherwise
# spoofable). Terraform sets this in lock step with lock_origin_to_cloudflare.
TRUST_CLOUDFLARE_IP=false
