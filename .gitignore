# Secrets / local env
.env
.env.local
.env.*.local

# Résumé PDF — never commit (contains personal contact details)
*.pdf

# OS / editor / local agent state
.DS_Store
*.log
.idea/
.vscode/
.claude/

# Go build artifacts
backend/bin/
backend/tmp/

# Generated Ent client — regenerate with `make generate-ent` (committed: schema only)
backend/ent/*
!backend/ent/generate.go
!backend/ent/schema/
!backend/ent/schema/**

# original full-res photo sources (resized copies live in frontend/public/photos)
pics/

# Terraform: local state, provider plugins, and any real tfvars
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
# .terraform.lock.hcl stays committed (pins provider versions)
